rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Private app — every read requires sign-in.
    // Writes are open to any authenticated user (5-player + admin trust model).
    match /tournaments/{tournamentId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;

      match /leaderboardSnapshot/{entryId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null;
      }
      match /fantasySnapshot/{teamId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null;
      }
    }
    match /players/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /fantasyLeagues/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /teams/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /scoringCache/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /exportMeta/{tournamentId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /agentExports/{tournamentId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    // Each user can only read/write their own profile document
    match /userProfiles/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
